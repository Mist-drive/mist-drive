# --- Public hostnames ---
DOMAIN=mist.localhost
# Host:port the BROWSER will use to PUT/GET presigned S3 URLs.
# Local dev:         localhost:9000       (minio port forwarded to host)
# With tls profile:  s3.mist.localhost    (Traefik routes s3.<domain>)
S3_DOMAIN=localhost:9000

# --- API ---
# generate with: openssl rand -base64 48   (must be >= 32 chars)
JWT_SECRET=
JWT_TTL=24h
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin
DEFAULT_QUOTA_BYTES=10737418240
UPLOAD_TTL_HOURS=24
CORS_ORIGINS=*
LOG_LEVEL=info

# --- MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# Disable the embedded MinIO web console. The API never uses it, and
# leaving it on adds attack surface (and a second login screen bots scan
# for). Flip to "on" only when you specifically need the console, and
# reach it over an SSH tunnel.
MINIO_BROWSER=off

# Internal S3 credentials the API uses (usually same as MINIO_ROOT_*)
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
