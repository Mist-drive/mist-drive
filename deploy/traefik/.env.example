# Domain — drives.${DOMAIN} and s3.${DOMAIN} must point to this server
DOMAIN=example.com
# Email used for Let's Encrypt certificate notifications
ACME_EMAIL=you@example.com

# =============
# MIST-DRIVE
# =============

# Required — generate with: openssl rand -base64 48
JWT_SECRET=

ADMIN_LOGIN=admin
# Required — change after first login
ADMIN_PASSWORD=

# Per-user storage quota in bytes (default: 10 GiB)
DEFAULT_QUOTA_BYTES=10737418240

# JWT session lifetime (default: 24h)
JWT_TTL=24h

# =============
# MINIO
# =============

# Also used as S3_ACCESS_KEY / S3_SECRET_KEY in mist-drive
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=

# =============
# SMTP (optional — leave blank to disable email notifications)
# =============

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# starttls | tls | none
SMTP_TLS=starttls
# Base URL for email links, e.g. https://drive.example.com
PUBLIC_URL=
