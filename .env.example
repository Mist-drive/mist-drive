# --- API ---
# Required. Generate a real one with: openssl rand -base64 48
JWT_SECRET=changeme-changeme-changeme-changeme-changeme
JWT_TTL=24h
ADMIN_LOGIN=admin
# Required. Change before deploying.
ADMIN_PASSWORD=admin
DEFAULT_QUOTA_BYTES=10737418240
UPLOAD_TTL_HOURS=24
LOG_LEVEL=info

# --- S3 / MinIO ---
# Internal host:port the API uses to talk to MinIO.
# Local dev / docker compose: minio:9000 (internal network)
# For make api-dev (air): overridden to localhost:9000 by Makefile
S3_ENDPOINT=minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Host:port the BROWSER uses for presigned PUT/GET URLs.
# Local dev:   localhost:9000
# Production:  s3.<your-domain>
S3_DOMAIN=localhost:9000

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# Flip to "on" only when you need the MinIO console (reach via SSH tunnel).
MINIO_BROWSER=off

# Email notifications (optional – leave SMTP_HOST blank to disable)
#
# Local testing with Mailpit (catches all mail, no real sending):
#   docker compose up mailpit   → UI at http://localhost:8025
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@mist-drive.local
SMTP_TLS=none
PUBLIC_URL=https://drive.example.com
#
# Production – use an external relay (handles deliverability/SPF/DKIM for you):
# Resend:  SMTP_HOST=smtp.resend.com  SMTP_PORT=587  SMTP_USER=resend  SMTP_PASSWORD=re_xxx  SMTP_TLS=starttls
# Brevo:   SMTP_HOST=smtp-relay.brevo.com  SMTP_PORT=587  SMTP_USER=your@email.com  SMTP_PASSWORD=xxx  SMTP_TLS=starttls
# Gmail:   SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USER=you@gmail.com  SMTP_PASSWORD=<app-password>  SMTP_TLS=starttls
#          (Gmail requires an App Password — google.com/search?q=gmail+app+password)
